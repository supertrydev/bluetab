{
  "manifest_version": 3,
  "name": "BlueTab",
  "version": "1.0.0",
  "key": "",
  "description": "One-click tab management for Chrome",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "unlimitedStorage",
    "commands",
    "contextMenus",
    "activeTab",
    "windows",
    "notifications",
    "search",
    "identity",
    "alarms",
    "sidePanel",
    "bookmarks"
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "host_permissions": [
    "https://supertry.net/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/floating-button.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "omnibox": {
    "keyword": "bt"
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "homepage_url": "https://supertry.net/bluetab",
  "action": {
    "default_icon": {
      "16": "src/assets/icon16.png",
      "32": "src/assets/icon32.png",
      "48": "src/assets/icon48.png",
      "64": "src/assets/icon48.png",
      "128": "src/assets/icon128.png",
      "256": "src/assets/icon128.png"
    }
  },
  "icons": {
    "16": "src/assets/icon16.png",
    "32": "src/assets/icon32.png",
    "48": "src/assets/icon48.png",
    "64": "src/assets/icon48.png",
    "128": "src/assets/icon128.png",
    "256": "src/assets/icon128.png"
  },
  "options_page": "src/options/index.html",
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+T"
      },
      "description": "Activate extension"
    },
    "save-all-tabs": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Save all tabs"
    },
    "restore-last-group": {
      "suggested_key": {
        "default": "Alt+R"
      },
      "description": "Restore last group"
    },
    "open-manager": {
      "suggested_key": {
        "default": "Alt+B"
      },
      "description": "Open BlueTab Manager"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}